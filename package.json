{
  "name": "fuschia-stock-panel",
  "version": "1.0.0",
  "description": "Fuschia / Etullen toptan perde stok yönetim paneli",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:schema": "node -e \"const{Pool}=require('pg');const fs=require('fs');const pool=new Pool({connectionString:process.env.DATABASE_URL,ssl:process.env.NODE_ENV==='production'?{rejectUnauthorized:false}:false});pool.query(fs.readFileSync('./db/schema.sql','utf8')).then(()=>{console.log('Schema uygulandı.');pool.end()}).catch(e=>{console.error(e.message);pool.end();process.exit(1)})\"",
    "db:seed": "node db/seed.js",
    "db:reset": "npm run db:seed"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "connect-pg-simple": "^9.0.1",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "method-override": "^3.0.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
