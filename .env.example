# ─────────────────────────────────────────────────────────────
# Fuschia Stok Paneli — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun.
# .env dosyasını GIT'e commit etmeyin!
# ─────────────────────────────────────────────────────────────

# PostgreSQL bağlantı URL'i
# Local:      postgresql://postgres:sifre@localhost:5432/fuschia_db
# Render.com: panelden "Connect" → "External Database URL"
DATABASE_URL=postgresql://postgres:sifre@localhost:5432/fuschia_db

# Oturum şifreleme anahtarı — güçlü ve rastgele bir değer girin
# Üretmek için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=buraya-guclu-rastgele-bir-anahtar-yazin

# Ortam: production | development
NODE_ENV=development

# Sunucu portu (Render.com bu değeri kendisi atar, değiştirmeyin)
PORT=3000
