<%- include('_header') %>

<div class="page-header">
  <h1 class="page-title">&#9986; Kesim / Sarf Girişi</h1>
</div>

<% if (success) { %>
<div class="alert alert-success">
  <span class="alert-icon">&#10003;</span>
  <span>Kesim kaydı başarıyla oluşturuldu!</span>
</div>
<% } %>
<% if (error) { %>
<div class="alert alert-danger">
  <span class="alert-icon">&#9888;</span>
  <span><%= error %></span>
</div>
<% } %>

<div class="card">
  <form action="/cutting-entry" method="POST" id="cutForm">

    <!-- LOT / BARKOD -->
    <div class="form-group">
      <label class="form-label" for="lot_barcode">Lot / Barkod <span class="req">*</span></label>
      <input type="text" id="lot_barcode" name="lot_barcode" required
             autofocus
             data-barcode-scan
             placeholder="Jalpersan barkodunu okutun veya yazın"
             value="<%= formData.lot_barcode || '' %>"
             autocomplete="off"
             inputmode="text"
             style="font-size:1.05rem;font-family:monospace">
      <div class="form-hint" id="lotHint">Lot barkodunu girin (ürün ve raf otomatik dolar) — ya da önce ürün kodunu yazıp mevcut lotlardan seçin.</div>
    </div>

    <!-- ÜRÜN KODU / KAYNAK RAF -->
    <div class="form-row">
      <div class="form-group">
        <label class="form-label" for="product_code">Ürün Kodu <span class="req">*</span></label>
        <input type="text" id="product_code" name="product_code" required
               placeholder="Örn: DT-04 — lot girilince de otomatik dolar"
               value="<%= formData.product_code || '' %>"
               autocomplete="off"
               inputmode="text"
               style="text-transform:uppercase;font-size:1.1rem;font-weight:700">
      </div>

      <div class="form-group">
        <label class="form-label" for="source_shelf_id">Kaynak Raf <span class="req">*</span></label>
        <select id="source_shelf_id" name="source_shelf_id" required disabled>
          <option value="">— Lot veya ürün kodu girin —</option>
        </select>
        <div class="form-hint" id="shelfTypeHint" style="display:none"></div>
      </div>
    </div>

    <!-- ÜRÜN KODUNA GÖRE MEVCUT LOTLAR (yardımcı liste) -->
    <div class="form-group" id="availableLotsGroup" style="display:none">
      <label class="form-label">Bu Üründe Stokta Olan Lotlar <span class="fs-sm text-muted fw-bold">— birine tıklayın</span></label>
      <div id="availableLotsList" style="display:flex;flex-wrap:wrap;gap:8px"></div>
    </div>

    <!-- KALAN METRE -->
    <div class="form-group" id="remainingGroup" style="display:none">
      <label class="form-label">Kalan Stok</label>
      <div class="stock-info-box" id="remainingBox">—</div>
    </div>

    <!-- ÇIKIŞ TİPİ / TARİH -->
    <div class="form-row">
      <div class="form-group">
        <label class="form-label" for="output_type">Çıkış Tipi <span class="req">*</span></label>
        <select id="output_type" name="output_type" required>
          <option value="">— Seç —</option>
          <option value="sales"      <%=formData.output_type==='sales'      ?'selected':''%>>&#128200; Satış</option>
          <option value="fire"       <%=formData.output_type==='fire'       ?'selected':''%>>&#128293; Fire</option>
          <option value="evaluation" <%=formData.output_type==='evaluation' ?'selected':''%>>&#128195; Değerlendirme</option>
        </select>
      </div>

      <div class="form-group">
        <label class="form-label" for="entry_date">Tarih <span class="req">*</span></label>
        <input type="date" id="entry_date" name="entry_date" required
               value="<%= formData.entry_date || new Date().toISOString().split('T')[0] %>">
      </div>
    </div>

    <!-- KESİM BİLGİLERİ -->
    <div class="form-row">
      <div class="form-group">
        <label class="form-label" for="cut_cm">Kesim (cm) <span class="req">*</span></label>
        <input type="number" id="cut_cm" name="cut_cm" required
               min="0.01" step="0.01" placeholder="Örn: 230"
               inputmode="decimal"
               value="<%= formData.cut_cm || '' %>">
      </div>
      <div class="form-group">
        <label class="form-label" for="quantity">Adet <span class="req">*</span></label>
        <input type="number" id="quantity" name="quantity" required
               min="1" step="1" placeholder="Örn: 14"
               inputmode="numeric"
               value="<%= formData.quantity || '' %>">
      </div>
    </div>

    <!-- HESAPLANAN ÇIKIŞ -->
    <div class="form-group">
      <label class="form-label">Hesaplanan Çıkış Metre</label>
      <div class="calc-box" id="calcBox">— m</div>
      <div class="form-hint">cut_cm &times; adet / 100 = toplam metre</div>
    </div>

    <!-- DEĞERLENDİRME RAFI (sadece evaluation seçiliyse) -->
    <div class="form-group" id="evalShelfGroup" style="display:none">
      <label class="form-label" for="target_shelf_id">Değerlendirme Rafı <span class="req">*</span></label>
      <select id="target_shelf_id" name="target_shelf_id">
        <option value="">— Raf Seç —</option>
        <% evalShelves.forEach(s => { %>
        <option value="<%= s.id %>" <%=formData.target_shelf_id==s.id?'selected':''%>>
          <%= s.shelf_code %>
        </option>
        <% }) %>
      </select>
    </div>

    <!-- HEDEF BİLGİSİ (satış/fire) -->
    <div class="form-group" id="targetInfo" style="display:none">
      <label class="form-label">Hedef Alan</label>
      <div class="stock-info-box has-value" id="targetInfoBox">—</div>
    </div>

    <div class="form-group">
      <label class="form-label" for="note">Not (isteğe bağlı)</label>
      <input type="text" id="note" name="note"
             placeholder="Açıklama varsa yazın"
             value="<%= formData.note || '' %>">
    </div>

    <div class="btn-group mt-2">
      <button type="submit" class="btn btn-success btn-lg" id="submitBtn" style="flex:1" disabled>
        &#9986; Kesimi Kaydet
      </button>
      <a href="/" class="btn btn-secondary btn-lg">İptal</a>
    </div>
  </form>
</div>

<!-- SON KESİMLER -->
<% if (recent && recent.length) { %>
<div class="card mt-3">
  <div class="card-title">Son Kesim Kayıtları</div>
  <div class="table-wrap resp-table">
    <table>
      <thead>
        <tr>
          <th>Tarih</th><th>Tip</th><th>Ürün</th><th>Lot</th>
          <th>Raf</th><th>cm</th><th>Adet</th><th>Metre</th>
        </tr>
      </thead>
      <tbody>
        <% recent.forEach(r => { %>
        <tr>
          <td data-label="Tarih"><%= new Date(r.entry_date).toLocaleDateString('tr-TR') %></td>
          <td data-label="Tip">
            <% if(r.output_type==='sales'){%><span class="badge badge-blue">Satış</span>
            <%}else if(r.output_type==='fire'){%><span class="badge badge-red">Fire</span>
            <%}else{%><span class="badge badge-yellow">Değer.</span><%}%>
          </td>
          <td data-label="Ürün" class="fw-bold"><%= r.product_code %></td>
          <td data-label="Lot"  style="font-family:monospace;font-size:.85rem"><%= r.lot_barcode %></td>
          <td data-label="Raf"><span class="badge badge-gray"><%= r.source_shelf %></span></td>
          <td data-label="cm"><%= r.cut_cm %></td>
          <td data-label="Adet"><%= r.quantity %></td>
          <td data-label="Metre" class="fw-bold text-danger"><%= Number(r.total_meter).toFixed(2) %> m</td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<script>
const lotInput     = document.getElementById('lot_barcode');
const productInput = document.getElementById('product_code');
const shelfSel     = document.getElementById('source_shelf_id');
const remainGrp    = document.getElementById('remainingGroup');
const remainBox    = document.getElementById('remainingBox');
const calcBox      = document.getElementById('calcBox');
const cutCmInput   = document.getElementById('cut_cm');
const qtyInput     = document.getElementById('quantity');
const outputSel    = document.getElementById('output_type');
const evalGrp      = document.getElementById('evalShelfGroup');
const evalSh       = document.getElementById('target_shelf_id');
const targetInfo   = document.getElementById('targetInfo');
const targetBox    = document.getElementById('targetInfoBox');
const submitBtn    = document.getElementById('submitBtn');
const lotHint      = document.getElementById('lotHint');
const shelfTypeHint = document.getElementById('shelfTypeHint');
const availableLotsGroup = document.getElementById('availableLotsGroup');
const availableLotsList  = document.getElementById('availableLotsList');

let currentRemaining = 0;
let shelvesData = [];

// ── Çıkış tipi değişince ──────────────────────────────────────
outputSel.addEventListener('change', updateOutputType);
function updateOutputType() {
  const v = outputSel.value;
  if (v === 'evaluation') {
    evalGrp.style.display = 'block';
    evalSh.required = true;
    targetInfo.style.display = 'none';
  } else {
    evalGrp.style.display = 'none';
    evalSh.required = false;
    evalSh.value = '';
    if (v === 'sales' || v === 'fire') {
      targetInfo.style.display = 'block';
      targetBox.textContent = v === 'sales' ? '→ SATIŞ alanına gönderilecek' : '→ FİRE alanına gönderilecek';
    } else {
      targetInfo.style.display = 'none';
    }
  }
  updateSubmitState();
}

// ── Lot barkodu girilince ürün + raf otomatik gelir ────────────
let lotTimer = null;
lotInput.addEventListener('input', () => {
  clearTimeout(lotTimer);
  lotTimer = setTimeout(lookupLot, 500);
});
lotInput.addEventListener('blur', lookupLot);

async function lookupLot() {
  const lot = lotInput.value.trim();
  if (!lot) { resetShelfOnly(); return; }
  shelfSel.disabled = true;
  shelfSel.innerHTML = '<option value="">Yükleniyor... &#9203;</option>';
  resetRemaining();
  try {
    const res  = await fetch('/api/lot-lookup?lot_barcode=' + encodeURIComponent(lot));
    const data = await res.json();
    if (data.status !== 'ok') {
      shelfSel.innerHTML = '<option value="">Bu lot barkodu bulunamadı</option>';
      shelfSel.disabled = true;
      lotHint.textContent = 'Bu lot barkodu stokta yok. Önce rulo girişi yapın.';
      lotHint.style.color = '#b91c1c';
      updateSubmitState();
      return;
    }
    productInput.value = data.product_code;
    shelvesData = data.shelves;
    shelfSel.innerHTML = '<option value="">— Raf Seç —</option>';
    shelvesData.forEach(s => {
      const opt = document.createElement('option');
      opt.value = s.shelf_id;
      opt.dataset.shelfType = s.shelf_type || 'main';
      opt.dataset.remaining = s.remaining_meter;
      const typeLabel = s.shelf_type === 'evaluation' ? ' [DEĞ.RAF]' : '';
      opt.textContent = `${s.shelf_code}${typeLabel} (kalan: ${Number(s.remaining_meter).toFixed(2)} m)`;
      shelfSel.appendChild(opt);
    });
    shelfSel.disabled = false;
    lotHint.textContent = shelvesData.length + ' rafta stok bulundu.';
    lotHint.style.color = '';
    if (shelvesData.length === 1) {
      shelfSel.selectedIndex = 1;
      shelfSel.dispatchEvent(new Event('change'));
    }
  } catch (e) {
    shelfSel.innerHTML = '<option value="">Hata oluştu</option>';
  }
  updateSubmitState();
}

// ── Ürün kodu girilince o üründeki mevcut lot/raf listesi gösterilir ──
let productTimer = null;
productInput.addEventListener('input', () => {
  const pos = productInput.selectionStart;
  productInput.value = productInput.value.toUpperCase();
  productInput.setSelectionRange(pos, pos);
  clearTimeout(productTimer);
  productTimer = setTimeout(lookupByProduct, 500);
});
productInput.addEventListener('change', lookupByProduct);

async function lookupByProduct() {
  const code = productInput.value.trim();
  if (!code) { availableLotsGroup.style.display = 'none'; availableLotsList.innerHTML = ''; return; }
  try {
    const res  = await fetch('/api/lots?product_code=' + encodeURIComponent(code));
    const rows = await res.json();
    availableLotsList.innerHTML = '';
    if (!rows.length) {
      availableLotsList.innerHTML = '<span class="fs-sm text-muted">Bu üründe stokta lot bulunamadı.</span>';
      availableLotsGroup.style.display = 'block';
      return;
    }
    rows.forEach(row => {
      const typeLabel = row.shelf_type === 'evaluation' ? ' [DEĞ.RAF]' : '';
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'btn btn-secondary btn-sm';
      btn.textContent = `${row.lot_barcode} — ${row.shelf_code}${typeLabel} (${Number(row.remaining_meter).toFixed(2)} m)`;
      btn.addEventListener('click', () => selectLotFromList(row));
      availableLotsList.appendChild(btn);
    });
    availableLotsGroup.style.display = 'block';
  } catch (e) {
    availableLotsGroup.style.display = 'none';
  }
}

function selectLotFromList(row) {
  lotInput.value = row.lot_barcode;
  const typeLabel = row.shelf_type === 'evaluation' ? ' [DEĞ.RAF]' : '';
  shelfSel.innerHTML = '';
  const opt = document.createElement('option');
  opt.value = row.shelf_id;
  opt.dataset.shelfType = row.shelf_type || 'main';
  opt.dataset.remaining = row.remaining_meter;
  opt.textContent = `${row.shelf_code}${typeLabel} (kalan: ${Number(row.remaining_meter).toFixed(2)} m)`;
  opt.selected = true;
  shelfSel.appendChild(opt);
  shelfSel.disabled = false;
  lotHint.textContent = 'Lot listeden seçildi.';
  lotHint.style.color = '';
  shelfSel.dispatchEvent(new Event('change'));
  updateSubmitState();
}

// ── Raf seçilince kalan stok ve tip bilgisi ────────────────────
shelfSel.addEventListener('change', () => {
  const opt = shelfSel.options[shelfSel.selectedIndex];
  if (!opt || !opt.value) {
    resetRemaining();
    shelfTypeHint.style.display = 'none';
    updateSubmitState();
    return;
  }
  currentRemaining = parseFloat(opt.dataset.remaining) || 0;
  updateRemainingBox(currentRemaining);
  remainGrp.style.display = 'block';

  if (opt.dataset.shelfType === 'evaluation') {
    shelfTypeHint.innerHTML = '&#128195; Değerlendirme rafından kesim — parça "kullanıldı" olarak işaretlenecek.';
    shelfTypeHint.style.display = 'block';
    shelfTypeHint.style.color = '#92400e';
  } else {
    shelfTypeHint.style.display = 'none';
  }
  recalcAndCheck();
});

function resetShelfOnly() {
  shelfSel.innerHTML = '<option value="">— Lot veya ürün kodu girin —</option>';
  shelfSel.disabled = true;
  shelfTypeHint.style.display = 'none';
  lotHint.textContent = 'Lot barkodunu girin (ürün ve raf otomatik dolar) — ya da önce ürün kodunu yazıp mevcut lotlardan seçin.';
  lotHint.style.color = '';
  resetRemaining();
  updateSubmitState();
}

function resetRemaining() {
  currentRemaining = 0;
  remainGrp.style.display = 'none';
  remainBox.textContent = '—';
  remainBox.className = 'stock-info-box';
}

function updateRemainingBox(val) {
  remainBox.textContent = val.toFixed(2) + ' m kalan';
  if (val <= 0)   remainBox.className = 'stock-info-box empty';
  else if (val < 10) remainBox.className = 'stock-info-box low';
  else               remainBox.className = 'stock-info-box has-value';
}

cutCmInput.addEventListener('input', recalcAndCheck);
qtyInput.addEventListener('input',   recalcAndCheck);

function recalcAndCheck() {
  const cm  = parseFloat(cutCmInput.value) || 0;
  const qty = parseInt(qtyInput.value, 10)  || 0;
  if (cm > 0 && qty > 0) {
    const total = Math.round(cm * qty / 100 * 100) / 100;
    calcBox.textContent = total.toFixed(2) + ' m';
    calcBox.classList.add('visible');
    if (currentRemaining > 0 && total > currentRemaining) {
      calcBox.className = 'calc-box visible over';
    } else {
      calcBox.className = 'calc-box visible';
    }
  } else {
    calcBox.classList.remove('visible');
  }
  updateSubmitState();
}

function updateSubmitState() {
  const hasProduct = productInput.value.trim();
  const hasLot     = lotInput.value.trim();
  const hasShelf   = shelfSel.value;
  const hasCm      = parseFloat(cutCmInput.value) > 0;
  const hasQty     = parseInt(qtyInput.value,10)  > 0;
  const hasType    = outputSel.value;
  const evalOk     = outputSel.value !== 'evaluation' || evalSh.value;
  const cm  = parseFloat(cutCmInput.value) || 0;
  const qty = parseInt(qtyInput.value,10)  || 0;
  const total = Math.round(cm * qty / 100 * 100) / 100;
  const stockOk = currentRemaining <= 0 || total <= currentRemaining;

  const ok = hasProduct && hasLot && hasShelf && hasCm && hasQty && hasType && evalOk && stockOk;
  submitBtn.disabled = !ok;
  if (!stockOk) {
    submitBtn.textContent = '⚠ Stok Yetersiz — Kayıt Yapılamaz';
  } else {
    submitBtn.textContent = '✂ Kesimi Kaydet';
  }
}

evalSh.addEventListener('change', updateSubmitState);

outputSel.dispatchEvent(new Event('change'));
if (lotInput.value) lookupLot();
if (productInput.value) lookupByProduct();
</script>

<script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
<script src="/barcode-scanner.js"></script>

<%- include('_footer') %>
