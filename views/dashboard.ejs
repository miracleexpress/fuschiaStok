<%- include('_header') %>

<div class="page-header">
  <h1 class="page-title">Dashboard</h1>
  <span class="fs-sm text-muted">
    <%= new Date().toLocaleDateString('tr-TR',{day:'2-digit',month:'long',year:'numeric'}) %>
  </span>
</div>

<% if (user.role === 'admin') { %>
<div class="alert" style="background:#fefce8;border:1.5px solid #fde047;color:#713f12;padding:12px 16px;margin-bottom:16px;border-radius:8px;font-size:.9rem">
  <span style="font-weight:700">&#128274; Admin Güvenliği:</span>
  Varsayılan şifreyi değiştirdiniz mi? Değiştirmediyseniz
  <a href="/users" style="color:#92400e;text-decoration:underline;font-weight:700">Kullanıcılar</a> sayfasından hemen değiştirin.
</div>
<% } %>

<!-- STAT CARDS -->
<div class="stat-grid">
  <div class="stat-card success">
    <span class="stat-value"><%= Number(summary.remaining_stock_meter||0).toFixed(2) %></span>
    <span class="stat-label">Kalan Stok (m)</span>
  </div>
  <div class="stat-card warning">
    <span class="stat-value"><%= Number(today.today_sales||0).toFixed(2) %></span>
    <span class="stat-label">Bugün Satış (m)</span>
  </div>
  <div class="stat-card danger">
    <span class="stat-value"><%= Number(today.today_fire||0).toFixed(2) %></span>
    <span class="stat-label">Bugün Fire (m)</span>
  </div>
  <div class="stat-card info">
    <span class="stat-value"><%= Number(today.today_eval||0).toFixed(2) %></span>
    <span class="stat-label">Bugün Değer. (m)</span>
  </div>
  <div class="stat-card">
    <span class="stat-value"><%= Number(summary.total_in_meter||0).toFixed(2) %></span>
    <span class="stat-label">Toplam Giriş (m)</span>
  </div>
  <div class="stat-card">
    <span class="stat-value"><%= activeLotCount %></span>
    <span class="stat-label">Aktif Lot</span>
  </div>
  <div class="stat-card">
    <span class="stat-value"><%= evalPieceCount %></span>
    <span class="stat-label">Değer. Parça</span>
  </div>
</div>

<!-- HIZLI İŞLEMLER -->
<div class="quick-actions mb-3">
  <a href="/roll-entry"          class="qa-btn primary"><span class="qa-icon">&#8679;</span>Rulo Girişi</a>
  <a href="/cutting-entry"       class="qa-btn success"><span class="qa-icon">&#9986;</span>Kesim / Sarf</a>
  <a href="/reports/roll-stock"  class="qa-btn"><span class="qa-icon">&#128230;</span>Rulo Stok</a>
  <a href="/reports/movements"   class="qa-btn"><span class="qa-icon">&#128257;</span>Hareketler</a>
</div>

<div class="form-row">
  <!-- Son Hareketler -->
  <div class="card" style="grid-column:span 2">
    <div class="card-title">Son 10 Hareket</div>
    <% if (!recentMovements.length) { %>
      <div class="empty-state"><span class="es-icon">&#128203;</span>Henüz hareket yok.</div>
    <% } else { %>
    <div class="table-wrap resp-table">
      <table>
        <thead>
          <tr>
            <th>Tip</th><th>Ürün</th><th>Lot</th>
            <th>Kaynak</th><th>Hedef</th><th>Metre</th><th>Tarih</th>
          </tr>
        </thead>
        <tbody>
          <% recentMovements.forEach(r => { %>
          <tr>
            <td data-label="Tip">
              <% if(r.movement_type==='roll_in'){%><span class="badge badge-green">Giriş</span>
              <%}else if(r.movement_type==='sales_out'){%><span class="badge badge-blue">Satış</span>
              <%}else if(r.movement_type==='fire_out'){%><span class="badge badge-red">Fire</span>
              <%}else if(r.movement_type==='evaluation_in'){%><span class="badge badge-yellow">Değer.↓</span>
              <%}else{%><span class="badge badge-yellow">Değer.↑</span><%}%>
            </td>
            <td data-label="Ürün" class="fw-bold"><%= r.product_code %></td>
            <td data-label="Lot" class="fs-sm"><%= r.lot_barcode %></td>
            <td data-label="Kaynak" class="fs-sm"><%= r.source_shelf||'—' %></td>
            <td data-label="Hedef"  class="fs-sm"><%= r.target_shelf||'—' %></td>
            <td data-label="Metre" class="fw-bold <%= r.meter>0?'text-success':'text-danger' %>">
              <%= Number(r.meter).toFixed(2) %> m
            </td>
            <td data-label="Tarih" class="fs-sm text-muted">
              <%= new Date(r.movement_date).toLocaleDateString('tr-TR') %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>

<div class="form-row mt-3">
  <!-- Raf Özeti -->
  <div class="card">
    <div class="card-title">Raf Bazlı Stok (Kalan &gt; 0)</div>
    <% if (!shelfStock.length) { %>
      <div class="empty-state"><span class="es-icon">&#127970;</span>Raflarda stok yok.</div>
    <% } else { %>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Raf</th><th>Kalan (m)</th></tr></thead>
        <tbody>
          <% shelfStock.forEach(s => { %>
          <tr>
            <td class="fw-bold"><span class="badge badge-gray"><%= s.shelf_code %></span></td>
            <td class="fw-bold text-success"><%= Number(s.remaining_meter).toFixed(2) %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <!-- En Çok Fire (son 30 gün) -->
  <div class="card">
    <div class="card-title">En Çok Fire — Son 30 Gün</div>
    <% if (!topFire.length) { %>
      <div class="empty-state"><span class="es-icon">&#128293;</span>Son 30 günde fire yok.</div>
    <% } else { %>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Ürün</th><th>Toplam Fire (m)</th><th>Adet</th></tr></thead>
        <tbody>
          <% topFire.forEach(r => { %>
          <tr>
            <td class="fw-bold"><%= r.product_code %></td>
            <td class="text-danger fw-bold"><%= Number(r.total_fire_meter).toFixed(2) %></td>
            <td><%= r.total_qty %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>

<%- include('_footer') %>
