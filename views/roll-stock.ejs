<%- include('_header') %>

<div class="page-header">
  <h1 class="page-title">&#128230; Stok</h1>
</div>

<div class="filter-bar">
  <form method="GET" action="/reports/roll-stock">
    <div class="form-group">
      <label class="form-label">Ürün Kodu</label>
      <input type="text" name="product_code" placeholder="DT-04"
             value="<%= filter.product_code||'' %>">
    </div>
    <div class="form-group">
      <label class="form-label">Lot / Barkod</label>
      <input type="text" name="lot_barcode" data-barcode-scan placeholder="JAL-..."
             value="<%= filter.lot_barcode||'' %>">
    </div>
    <div class="form-group">
      <label class="form-label">Ürün ID</label>
      <input type="text" name="product_serial" data-barcode-scan placeholder="UR-..."
             value="<%= filter.product_serial||'' %>">
    </div>
    <div class="form-group">
      <label class="form-label">Raf</label>
      <input type="text" name="shelf_code" placeholder="1-A"
             value="<%= filter.shelf_code||'' %>">
    </div>
    <div class="form-group">
      <label class="form-label">Sıralama</label>
      <select name="sort">
        <option value=""               <%=!filter.sort           ?'selected':''%>>Ürün Kodu</option>
        <option value="remaining_desc" <%=filter.sort==='remaining_desc'?'selected':''%>>Kalan ↓</option>
        <option value="remaining_asc"  <%=filter.sort==='remaining_asc' ?'selected':''%>>Kalan ↑</option>
      </select>
    </div>
    <button type="submit" class="btn btn-primary">Filtrele</button>
    <a href="/reports/roll-stock" class="btn btn-secondary">Temizle</a>
    <a href="/reports/rulo-stok.csv?<%= new URLSearchParams(filter).toString() %>"
       class="btn btn-secondary" style="color:#059669">&#8595; CSV</a>
  </form>
</div>

<%
  function renderStockTable(rows) {
    let totalIn=0, totalOut=0, totalRem=0;
    rows.forEach(r => {
      totalIn  += parseFloat(r.total_in_meter  || 0);
      totalOut += parseFloat(r.total_out_meter || 0);
      totalRem += parseFloat(r.remaining_meter || 0);
    });
    return { totalIn, totalOut, totalRem };
  }
  const regTotals  = renderStockTable(regulationRows);
  const mainTotals = renderStockTable(mainRows);
  const evalTotals = renderStockTable(evalRows);
%>

<!-- DEĞERLENDİRME -->
<div class="card mb-3">
  <div class="card-title">&#128195; Değerlendirme (<%= evalRows.length %>)</div>
  <% if (!evalRows.length) { %>
  <div class="empty-state"><span class="es-icon">&#128195;</span>Değerlendirme rafında stok kaydı bulunamadı.</div>
  <% } else { %>
  <div class="table-wrap resp-table">
    <table>
      <thead>
        <tr>
          <th>Ürün Kodu</th><th>Ürün Adı</th><th>Lot / Barkod</th><th>Ürün ID</th><th>Raf</th>
          <th style="text-align:right">Giriş (m)</th><th style="text-align:right">Çıkış (m)</th><th style="text-align:right">Kalan (m)</th>
        </tr>
      </thead>
      <tbody>
        <% evalRows.forEach(r => { %>
        <tr>
          <td data-label="Ürün Kodu" class="fw-bold fs-lg"><%= r.product_code %></td>
          <td data-label="Ürün Adı"  class="text-muted fs-sm"><%= r.product_name||'—' %></td>
          <td data-label="Lot" style="font-family:monospace;font-size:.88rem"><%= r.lot_barcode %></td>
          <td data-label="Ürün ID" style="font-family:monospace;font-size:.85rem"><%= r.product_serial||'—' %></td>
          <td data-label="Raf"><span class="badge badge-gray"><%= r.shelf_code %></span></td>
          <td data-label="Giriş (m)"  class="text-success" style="text-align:right"><%= Number(r.total_in_meter).toFixed(2) %></td>
          <td data-label="Çıkış (m)"  class="text-danger"  style="text-align:right"><%= Number(r.total_out_meter).toFixed(2) %></td>
          <td data-label="Kalan (m)"  class="fw-black fs-lg" style="text-align:right"><%= Number(r.remaining_meter).toFixed(2) %></td>
        </tr>
        <% }) %>
      </tbody>
      <tfoot>
        <tr class="tfoot-total">
          <td colspan="5">TOPLAM (<%= evalRows.length %> kayıt)</td>
          <td class="text-success" style="text-align:right"><%= evalTotals.totalIn.toFixed(2) %></td>
          <td class="text-danger"  style="text-align:right"><%= evalTotals.totalOut.toFixed(2) %></td>
          <td class="fw-black"     style="text-align:right"><%= evalTotals.totalRem.toFixed(2) %></td>
        </tr>
      </tfoot>
    </table>
  </div>
  <% } %>
</div>

<!-- MERKEZ DEPO -->
<div class="card mb-3">
  <div class="card-title">&#127970; Merkez Depo (<%= mainRows.length %>)</div>
  <% if (!mainRows.length) { %>
  <div class="empty-state"><span class="es-icon">&#127970;</span>Merkez depoda stok kaydı bulunamadı.</div>
  <% } else { %>
  <div class="table-wrap resp-table">
    <table>
      <thead>
