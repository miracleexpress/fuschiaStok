          <th>Ürün Kodu</th><th>Ürün Adı</th><th>Lot / Barkod</th><th>Ürün ID</th><th>Raf</th>
          <th style="text-align:right">Giriş (m)</th><th style="text-align:right">Çıkış (m)</th><th style="text-align:right">Kalan (m)</th>
        </tr>
      </thead>
      <tbody>
        <% mainRows.forEach(r => { %>
        <tr>
          <td data-label="Ürün Kodu" class="fw-bold fs-lg"><%= r.product_code %></td>
          <td data-label="Ürün Adı"  class="text-muted fs-sm"><%= r.product_name||'—' %></td>
          <td data-label="Lot" style="font-family:monospace;font-size:.88rem"><%= r.lot_barcode %></td>
          <td data-label="Ürün ID" style="font-family:monospace;font-size:.85rem"><%= r.product_serial||'—' %></td>
          <td data-label="Raf"><span class="badge badge-gray"><%= r.shelf_code %></span></td>
          <td data-label="Giriş (m)"  class="text-success" style="text-align:right"><%= Number(r.total_in_meter).toFixed(2) %></td>
          <td data-label="Çıkış (m)"  class="text-danger"  style="text-align:right"><%= Number(r.total_out_meter).toFixed(2) %></td>
          <td data-label="Kalan (m)"  class="fw-black fs-lg" style="text-align:right"><%= Number(r.remaining_meter).toFixed(2) %></td>
        </tr>
        <% }) %>
      </tbody>
      <tfoot>
        <tr class="tfoot-total">
          <td colspan="5">TOPLAM (<%= mainRows.length %> kayıt)</td>
          <td class="text-success" style="text-align:right"><%= mainTotals.totalIn.toFixed(2) %></td>
          <td class="text-danger"  style="text-align:right"><%= mainTotals.totalOut.toFixed(2) %></td>
          <td class="fw-black"     style="text-align:right"><%= mainTotals.totalRem.toFixed(2) %></td>
        </tr>
      </tfoot>
    </table>
  </div>
  <% } %>
</div>

<!-- REGÜLE DEPO -->
<div class="card mb-3">
  <div class="card-title">&#128230; Regüle Depo (<%= regulationRows.length %>)</div>
  <% if (!regulationRows.length) { %>
  <div class="empty-state"><span class="es-icon">&#128230;</span>Regüle depoda stok kaydı bulunamadı.</div>
  <% } else { %>
  <div class="table-wrap resp-table">
    <table>
      <thead>
        <tr>
          <th>Ürün Kodu</th><th>Ürün Adı</th><th>Lot / Barkod</th><th>Ürün ID</th><th>Raf</th>
          <th style="text-align:right">Giriş (m)</th><th style="text-align:right">Çıkış (m)</th><th style="text-align:right">Kalan (m)</th>
        </tr>
      </thead>
      <tbody>
        <% regulationRows.forEach(r => { %>
        <tr>
          <td data-label="Ürün Kodu" class="fw-bold fs-lg"><%= r.product_code %></td>
          <td data-label="Ürün Adı"  class="text-muted fs-sm"><%= r.product_name||'—' %></td>
          <td data-label="Lot" style="font-family:monospace;font-size:.88rem"><%= r.lot_barcode %></td>
          <td data-label="Ürün ID" style="font-family:monospace;font-size:.85rem"><%= r.product_serial||'—' %></td>
          <td data-label="Raf"><span class="badge badge-gray"><%= r.shelf_code %></span></td>
          <td data-label="Giriş (m)"  class="text-success" style="text-align:right"><%= Number(r.total_in_meter).toFixed(2) %></td>
          <td data-label="Çıkış (m)"  class="text-danger"  style="text-align:right"><%= Number(r.total_out_meter).toFixed(2) %></td>
          <td data-label="Kalan (m)"  class="fw-black fs-lg" style="text-align:right"><%= Number(r.remaining_meter).toFixed(2) %></td>
        </tr>
        <% }) %>
      </tbody>
      <tfoot>
        <tr class="tfoot-total">
          <td colspan="5">TOPLAM (<%= regulationRows.length %> kayıt)</td>
          <td class="text-success" style="text-align:right"><%= regTotals.totalIn.toFixed(2) %></td>
          <td class="text-danger"  style="text-align:right"><%= regTotals.totalOut.toFixed(2) %></td>
          <td class="fw-black"     style="text-align:right"><%= regTotals.totalRem.toFixed(2) %></td>
        </tr>
      </tfoot>
    </table>
  </div>
  <% } %>
</div>

<script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
<script src="/barcode-scanner.js"></script>

<%- include('_footer') %>
