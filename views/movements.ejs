<%- include('_header') %>

<div class="page-header">
  <h1 class="page-title">&#128257; Stok Hareketleri</h1>
</div>

<div class="filter-bar">
  <form method="GET" action="/reports/movements">
    <div class="form-group">
      <label class="form-label">Başlangıç</label>
      <input type="date" name="date_from" value="<%= filter.date_from||'' %>">
    </div>
    <div class="form-group">
      <label class="form-label">Bitiş</label>
      <input type="date" name="date_to" value="<%= filter.date_to||'' %>">
    </div>
    <div class="form-group">
      <label class="form-label">Hareket Tipi</label>
      <select name="movement_type">
        <option value="">Tümü</option>
        <option value="roll_in"        <%=filter.movement_type==='roll_in'        ?'selected':''%>>Rulo Giriş</option>
        <option value="sales_out"      <%=filter.movement_type==='sales_out'      ?'selected':''%>>Satış Çıkış</option>
        <option value="fire_out"       <%=filter.movement_type==='fire_out'       ?'selected':''%>>Fire Çıkış</option>
        <option value="evaluation_out" <%=filter.movement_type==='evaluation_out' ?'selected':''%>>Değerlendirme Çıkış</option>
        <option value="evaluation_in"  <%=filter.movement_type==='evaluation_in'  ?'selected':''%>>Değerlendirme Giriş</option>
      </select>
    </div>
    <div class="form-group">
      <label class="form-label">Ürün Kodu</label>
      <input type="text" name="product_code" placeholder="DT-04" value="<%= filter.product_code||'' %>">
    </div>
    <div class="form-group">
      <label class="form-label">Lot / Barkod</label>
      <input type="text" name="lot_barcode" placeholder="JAL-..." value="<%= filter.lot_barcode||'' %>">
    </div>
    <div class="form-group">
      <label class="form-label">Kullanıcı</label>
      <select name="username">
        <option value="">Tümü</option>
        <% users.forEach(u => { %>
        <option value="<%= u.username %>" <%=filter.username===u.username?'selected':''%>><%= u.username %></option>
        <% }) %>
      </select>
    </div>
    <button type="submit" class="btn btn-primary">Filtrele</button>
    <a href="/reports/movements" class="btn btn-secondary">Temizle</a>
    <a href="/reports/hareketler.csv?<%= new URLSearchParams(filter).toString() %>"
       class="btn btn-secondary" style="color:#059669">&#8595; CSV</a>
  </form>
</div>

<div class="card">
  <% if (!rows.length) { %>
  <div class="empty-state"><span class="es-icon">&#128257;</span>Hareket kaydı bulunamadı.</div>
  <% } else { %>
  <div class="table-wrap resp-table">
    <table>
      <thead>
        <tr>
          <th>Tarih</th><th>Tip</th><th>Ürün</th><th>Lot</th>
          <th>Kaynak</th><th>Hedef</th><th>cm</th><th>Adet</th>
          <th style="text-align:right">Metre</th><th>Kaydeden</th><th>Not</th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(r => { %>
        <tr>
          <td data-label="Tarih"><%= new Date(r.movement_date).toLocaleDateString('tr-TR') %></td>
          <td data-label="Tip">
            <% if(r.movement_type==='roll_in'){%><span class="badge badge-green">Rulo Giriş</span>
            <%}else if(r.movement_type==='sales_out'){%><span class="badge badge-blue">Satış Çıkış</span>
            <%}else if(r.movement_type==='fire_out'){%><span class="badge badge-red">Fire Çıkış</span>
            <%}else{%><span class="badge badge-yellow">Değer. Çıkış</span><%}%>
          </td>
          <td data-label="Ürün"   class="fw-bold"><%= r.product_code %></td>
          <td data-label="Lot"    style="font-family:monospace;font-size:.82rem"><%= r.lot_barcode %></td>
          <td data-label="Kaynak" class="fs-sm"><%= r.source_shelf||'—' %></td>
          <td data-label="Hedef"  class="fs-sm"><%= r.target_shelf||'—' %></td>
          <td data-label="cm"     class="fs-sm"><%= r.cut_cm||'—' %></td>
          <td data-label="Adet"   class="fs-sm"><%= r.quantity||'—' %></td>
          <td data-label="Metre"  class="fw-bold <%= r.meter>0?'text-success':'text-danger' %>" style="text-align:right">
            <%= Number(r.meter).toFixed(2) %>
          </td>
          <td data-label="Kaydeden" class="fs-sm text-muted"><%= r.created_by %></td>
          <td data-label="Not"       class="fs-sm text-muted"><%= r.note||'—' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <p class="fs-sm text-muted mt-1">Son 200 hareket gösteriliyor.</p>
  <% } %>
</div>

<%- include('_footer') %>
